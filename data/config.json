{
  "version": "1.0",
  "ai": {
    "provider": "gemini",
    "model": "gemini-2.5-flash",
    "api_key_env": "GOOGLE_API_KEY",
    "temperature": 0.3,
    "max_tokens": 32768,
    "languages": [
      "en"
    ]
  },
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 50
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "LWN.net",
        "url": "https://lwn.net/headlines/full_text?key=${LWN_KEY}",
        "enabled": false,
        "category": "linux-kernel"
      },
      {
        "name": "Fox News",
        "url": "https://moxie.foxnews.com/google-publisher/latest.xml",
        "enabled": true,
        "category": "news"
      },
      {
        "name": "The Guardian - US",
        "url": "https://www.theguardian.com/us-news/rss",
        "enabled": true,
        "category": "news"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  }
}